# Sentry DSN — copy from your Sentry project's "Client Keys" page.
# When this is blank Sentry is completely disabled (no overhead in dev).
WXT_SENTRY_DSN=

# Optional: override the release name sent to Sentry.
# Defaults to the version field in manifest.json (e.g. "1.0.0").
WXT_SENTRY_RELEASE=

# Optional: force-enable Sentry even outside of production mode.
# Set to "true" to test Sentry locally without doing a full production build.
WXT_SENTRY_ENABLED=

# Optional: default Giphy API key used by the extension when no per-user
# override is saved in Options > Developers.
WXT_GIPHY_API_KEY=

# GitHub repository slug (owner/repo) used by the update checker to fetch
# the latest release from the GitHub Releases API.
# Example: jheysaaz/clipio
WXT_GITHUB_REPO=jheysaaz/clipio

# Base URL for the Clipio website. Used by the background service worker to
# construct the onboarding URL opened on first install.
# Example: https://clipio.xyz
WXT_WEBSITE_URL=https://clipio.xyz

# ---------------------------------------------------------------------------
# The following variables are only needed during CI / production builds to
# upload source maps to Sentry. They are never embedded into the extension.
# ---------------------------------------------------------------------------

# Your Sentry user auth token (Settings → Auth Tokens → Create Token).
# Needs the "project:releases" and "org:read" scopes.
SENTRY_AUTH_TOKEN=

# Your Sentry organisation slug (visible in the Sentry URL: sentry.io/organizations/<slug>)
SENTRY_ORG=

# Your Sentry project slug (visible in the Sentry URL: sentry.io/organizations/<org>/projects/<slug>)
SENTRY_PROJECT=
