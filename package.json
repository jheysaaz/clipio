{
  "name": "clipio",
  "displayName": "Clipio — Snippets Manager",
  "description": "A powerful browser extension for managing and inserting snippets with lightning speed and increase your productivity.",
  "version": "1.4.0",
  "type": "module",
  "scripts": {
    "dev": "wxt",
    "dev:firefox": "wxt -b firefox",
    "build": "wxt build",
    "build:firefox": "wxt build -b firefox",
    "zip": "wxt zip",
    "zip:firefox": "wxt zip -b firefox",
    "compile": "tsc --noEmit",
    "postinstall": "wxt prepare",
    "format": "prettier --write \"./**/*.{ts,tsx,js,jsx,json,css,html}\"",
    "format:check": "prettier --check \"./**/*.{ts,tsx,js,jsx,json,css,html}\"",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "playwright test",
    "test:e2e:headed": "playwright test --headed",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:debug": "playwright test --debug"
  },
  "dependencies": {
    "@platejs/basic-nodes": "^52.0.11",
    "@platejs/floating": "^52.0.11",
    "@platejs/slate": "^52.3.4",
    "@radix-ui/react-alert-dialog": "^1.1.15",
    "@radix-ui/react-checkbox": "^1.3.3",
    "@radix-ui/react-label": "^2.1.8",
    "@radix-ui/react-progress": "^1.1.8",
    "@radix-ui/react-radio-group": "^1.3.8",
    "@radix-ui/react-scroll-area": "^1.2.10",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-separator": "^1.1.8",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-tabs": "^1.1.13",
    "@sentry/browser": "^10.43.0",
    "@sentry/core": "^10.43.0",
    "@sentry/react": "^10.43.0",
    "@wxt-dev/i18n": "^0.2.5",
    "canvas-confetti": "^1.9.4",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "fflate": "^0.8.2",
    "lucide-react": "^0.577.0",
    "platejs": "^52.3.4",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "tailwind-merge": "^3.5.0",
    "tailwindcss": "^4.2.1",
    "tailwindcss-animate": "^1.0.7"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@sentry/vite-plugin": "^5.1.1",
    "@tailwindcss/vite": "^4.2.1",
    "@types/canvas-confetti": "^1.9.0",
    "@types/node": "^25.4.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.2.0",
    "@vitest/coverage-v8": "^4.1.0",
    "@wxt-dev/module-react": "^1.2.1",
    "fake-indexeddb": "^6.2.5",
    "happy-dom": "^20.8.3",
    "prettier": "^3.8.1",
    "typescript": "~5.9.3",
    "unplugin-fonts": "^1.4.0",
    "vite": "^7.0.0",
    "vitest": "^4.1.0",
    "wxt": "^0.20.18"
  }
}
